{
  "name": "ezha-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "type-check": "npm run typecheck",
    "format": "prettier --write package.json src/app/AppShell.vue src/components/FoodEntryCard.vue src/features/library/FoodEditorDialog.vue src/features/library/LibraryPage.vue src/features/today/TodayPage.vue src/style.css",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "pwa:assets": "vite-pwa-assets-generator --preset minimal-2023 public/logo.svg"
  },
  "dependencies": {
    "@radix-icons/vue": "^1.0.0",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^13.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "shadcn-vue": "^2.4.3",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.29",
    "vue-router": "^4.5.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.21",
    "oxlint": "^1.12.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.2.5"
  }
}
